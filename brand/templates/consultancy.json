{
  "name": "consultancy",
  "description": "Consultancy / agency: professional tone, .com mandatory, company name registration check.",
  "stages": [
    {
      "type": "score",
      "scorers": ["syllables", "stress_pattern", "spelling_transparency", "sound_symbolism", "novelty", "letter_balance", "name_length"]
    },
    {
      "type": "filter",
      "top_n": 300,
      "by": "spelling_transparency"
    },
    {
      "type": "score",
      "scorers": ["substring_hazards", "cross_linguistic"]
    },
    {
      "type": "score",
      "scorers": ["dns_com"]
    },
    {
      "type": "filter",
      "rules": {"dns_com": true}
    },
    {
      "type": "score",
      "scorers": ["whois_com"]
    },
    {
      "type": "filter",
      "rules": {"whois_com": true}
    }
  ]
}
